{
  "name": "adapthub-landing-page",
  "version": "1.0.0",
  "private": true,
  "description": "High-performance adaptive learning interface for competitive examinations.",
  "license": "PolyForm-Noncommercial-1.0.0",
  "scripts": {
    "dev": "astro dev",
    "partytown": "bunx partytown copylib public/~partytown",
    "prebuild": "bunx partytown copylib public/~partytown",
    "build": "astro build",
    "preview": "astro preview",
    "lint": "biome check",
    "gen:skills": "bun run scripts/gen-skills.ts",
    "format": "biome format --write",
    "type-check": "astro check",
    "pages:deploy": "bun run build && bunx wrangler pages deploy dist --project-name adapthub --branch main"
  },
  "dependencies": {
    "@astrojs/react": "^6.0.1",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/geist-mono": "^5.2.8",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/lora": "^5.2.8",
    "@qwik.dev/partytown": "^0.14.0",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-visually-hidden": "^1.2.7",
    "@tailwindcss/vite": "^4.3.2",
    "astro": "^7.0.9",
    "clsx": "^2.1.1",
    "lucide-react": "^1.24.0",
    "motion": "^12.42.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@biomejs/biome": "2.5.4",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.2",
    "typescript": "5.9.3",
    "wrangler": "^4.111.0"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
