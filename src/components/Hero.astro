---
import HeroBackground from "./HeroBackground";
import SectionSpotlight from "./SectionSpotlight";
import ParallaxDashboard from "./ParallaxDashboard";
import SpotlightButton from "./SpotlightButton";
import { CONTENT } from "../constants/content";
import heroImage from "../assets/hero.avif";
import { getImage } from "astro:assets";
const { src: optimizedHeroImg } = await getImage({ src: heroImage, width: 1200, format: 'avif' });
---

<section
  class="relative min-h-[100svh] flex flex-col bg-void px-4 sm:px-6 md:px-8 selection:bg-brand-teal/30 selection:text-white overflow-hidden"
  aria-label="Cognitive Calibration Hero"
>
  {/* ── Environment & Atmosphere ── */}
  <HeroBackground client:idle />
  <SectionSpotlight client:idle color="rgba(13, 148, 136, 0.14)" size={600} />

  {/* Cinematic Film Grain */}
  <svg
    class="absolute inset-0 w-full h-full pointer-events-none z-[1] opacity-[0.03] mix-blend-screen"
    aria-hidden="true"
  >
    <filter id="hero-grain">
      <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="4" stitchTiles="stitch" />
      <feColorMatrix type="saturate" values="0" />
    </filter>
    <rect width="100%" height="100%" filter="url(#hero-grain)" />
  </svg>

  {/* ── Core Layout Container ── */}
  <div class="relative z-elevate flex-1 flex flex-col items-center justify-center w-full max-w-[1200px] mx-auto pt-24 pb-8 sm:pt-28 sm:pb-12 lg:pt-32 lg:pb-16">
      
    {/* Typographic Drama */}
    <div class="relative z-20 text-center hero-stagger w-full px-4 mb-5" style="--i:0">
      {/* Deep Radial Halo behind typography */}
      <div
        class="absolute -top-[50%] left-1/2 -translate-x-1/2 w-[80%] h-[200%] pointer-events-none select-none opacity-40 mix-blend-screen"
        style="background:radial-gradient(circle, rgba(13,148,136,0.15) 0%, transparent 60%)"
        aria-hidden="true"
      />
      <h1 class="text-4xl sm:text-5xl md:text-6xl lg:text-[4.5rem] font-bold text-white tracking-tight leading-[1.1]">
        {CONTENT.hero.title.line1}
        <span class="block text-[#10b981] font-semibold mt-3" style="font-family: 'Dancing Script', cursive; font-size: 1.25em; line-height: 1; letter-spacing: normal;">
          {CONTENT.hero.title.highlight}
        </span>
      </h1>
    </div>

    {/* Description */}
    <div class="relative z-20 text-center hero-stagger w-full px-4 mb-6" style="--i:1">
      <p data-speakable class="text-zinc-400 text-sm sm:text-base lg:text-[1.0625rem] leading-relaxed max-w-2xl mx-auto selection:bg-brand-teal/30 selection:text-white">
        {CONTENT.hero.description}
      </p>
    </div>

    {/* Primary Action Button */}
    <div class="relative z-20 flex justify-center hero-stagger w-full px-4 mb-10 sm:mb-12" style="--i:2">
      <div class="relative group">
        <SpotlightButton
          client:idle
          href={CONTENT.links.app}
          target="_blank"
          rel="noopener noreferrer"
          className="relative overflow-hidden px-8 sm:px-10 py-3.5 sm:py-4 bg-accent-yellow text-black font-semibold text-sm md:text-[0.9375rem] rounded-lg shadow-[0_0_32px_rgba(252,211,77,0.15)] hover:shadow-[0_0_56px_rgba(252,211,77,0.35)] flex items-center justify-center gap-2.5 transition-all duration-300 touch-manipulation whitespace-nowrap"
        >
          <span class="relative z-10 flex items-center gap-2">
            {CONTENT.hero.cta.primary}
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M7 17L17 7" /><path d="M7 7h10v10" />
            </svg>
          </span>
        </SpotlightButton>
      </div>
    </div>

    {/* Dashboard Mockup */}
    <div class="relative z-20 w-full max-w-4xl px-4 hero-stagger" style="--i:3">
      {/* Ambient Glow behind the mockup */}
      <div class="absolute -inset-4 sm:-inset-10 bg-brand-teal/10 blur-[120px] rounded-full opacity-60 pointer-events-none -z-10"></div>
      
      <ParallaxDashboard client:idle heroImage={optimizedHeroImg} />
    </div>

    {/* ── Lower Zone: High-Fidelity Telemetry ── */}
    <div class="relative z-20 w-full pt-8 sm:pt-10 mt-12 sm:mt-16 lg:mt-24 border-t border-white/[0.06] hero-stagger" style="--i:4">
      <div class="flex flex-wrap lg:flex-nowrap items-end justify-between gap-y-10">

        {/* High-Fidelity Telemetry // Avant-Garde Overhaul */}
        <dl class="group/telemetry flex flex-col sm:flex-row items-start lg:items-end gap-16 lg:gap-32 w-full lg:w-auto mt-4 lg:mt-0">
          
          {/* Node 1: Volume */}
          <div class="relative flex flex-col transition-transform duration-700 ease-[cubic-bezier(0.19,1,0.22,1)] hover:translate-x-4 cursor-crosshair">
            <dt class="font-mono text-[10px] text-zinc-500 uppercase tracking-[0.4em] mb-4 flex items-center gap-3">
              <span class="w-1 h-1 bg-brand-teal animate-pulse opacity-70" aria-hidden="true"></span>
              [01] Volume // '26
            </dt>
            <dd class="text-[3.5rem] lg:text-[5.5rem] font-light tracking-tighter leading-[0.85] text-white transition-colors duration-500 group-hover/telemetry:text-zinc-800 hover:text-white! flex items-start m-0">
              <span aria-hidden="true">2.58<span class="font-serif italic text-zinc-400 text-3xl lg:text-4xl ml-2 mt-2">L</span></span>
              <span class="sr-only">2.58 Lakh</span>
            </dd>
          </div>

          {/* Node 2: Rarity */}
          <div class="relative flex flex-col transition-transform duration-700 ease-[cubic-bezier(0.19,1,0.22,1)] hover:translate-x-4 cursor-crosshair">
            <dt class="font-mono text-[10px] text-zinc-500 uppercase tracking-[0.4em] mb-4">
              [02] 99.99%ile
            </dt>
            <dd class="text-[3.5rem] lg:text-[5.5rem] font-light tracking-tighter leading-[0.85] text-white transition-colors duration-500 group-hover/telemetry:text-zinc-800 hover:text-white! flex items-start m-0">
              <span aria-hidden="true"><span class="font-serif italic text-zinc-400 text-4xl lg:text-[3rem] mr-3 mt-1 lg:mt-3 leading-none">&lt;</span>30</span>
              <span class="sr-only">Fewer than 30</span>
            </dd>
          </div>

          {/* Node 3: Access */}
          <div class="relative flex flex-col transition-transform duration-700 ease-[cubic-bezier(0.19,1,0.22,1)] hover:translate-x-4 cursor-crosshair">
            <dt class="font-mono text-[10px] text-zinc-500 uppercase tracking-[0.4em] mb-4">
              [03] Platform Fee
            </dt>
            <dd class="text-[3.5rem] lg:text-[5.5rem] font-light tracking-tighter leading-[0.85] text-white transition-colors duration-500 group-hover/telemetry:text-zinc-800 hover:text-white! flex items-start m-0">
              <span aria-hidden="true"><span class="font-serif italic text-zinc-400 text-4xl lg:text-[3rem] mr-3 mt-1 lg:mt-3 leading-none">₹</span>0</span>
              <span class="sr-only">0 rupees platform fee</span>
            </dd>
          </div>

        </dl>

        {/* Downward Intent Vector */}
        <div class="hidden lg:flex flex-col items-center gap-3 select-none pb-1" aria-hidden="true">
          <span class="font-mono text-[9px] text-zinc-500 tracking-[0.2em] uppercase origin-bottom -rotate-90 translate-y-2 opacity-0 hero-fade" style="--delay: 1500ms">
            Scroll
          </span>
          <div class="w-px h-12 bg-gradient-to-b from-zinc-800 to-transparent"></div>
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-zinc-500 hero-scroll-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 5v14" /><path d="m19 12-7 7-7-7" />
          </svg>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  /* ── Reduced Motion Guardrails ── */
  @media (prefers-reduced-motion: reduce) {
    .hero-stagger {
      opacity: 1 !important;
      transform: none !important;
      animation: none !important;
    }
  }
</style>
