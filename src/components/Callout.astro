---
interface Props {
  label: string;
  children: astroHTML.JSX.Element;
  cornerTabs?: boolean;
  class?: string;
}

const { label, cornerTabs = false, class: className = '' } = Astro.props;
---

<div class={`mb-12 border border-brand-teal/30 bg-brand-teal/[0.03] p-6 sm:p-8 relative ${className}`}>
  {cornerTabs && (
    <>
      <div class="absolute -top-px -left-px w-3 h-3 border-t-2 border-l-2 border-brand-teal" aria-hidden="true"></div>
      <div class="absolute -bottom-px -right-px w-3 h-3 border-b-2 border-r-2 border-brand-teal" aria-hidden="true"></div>
    </>
  )}
  <p class="font-mono text-[10px] md:text-xs text-brand-teal uppercase tracking-[0.2em] mb-4">[ {label} ]</p>
  <div class="space-y-3 speakable-content text-zinc-300 text-lg leading-relaxed" data-speakable>
    <slot />
  </div>
</div>