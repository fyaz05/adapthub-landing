---
interface Props {
  links: { label: string; href: string; class?: string }[];
  variant?: 'simple' | 'centered' | 'pricing';
}

const { links, variant = 'simple' } = Astro.props;
---

{ variant === 'pricing' && (
  <nav aria-label="Related CAT prep guides" class="container mx-auto px-4 sm:px-6 md:px-12 lg:px-24 max-w-[1800px] py-12 border-t border-white/[0.04]">
    <p class="font-mono text-[10px] text-zinc-500 uppercase tracking-[0.2em] mb-4">Related guides</p>
    <ul class="flex flex-wrap gap-x-6 gap-y-3 text-sm text-zinc-400">
      {links.map(link => (
        <li>
          <a 
            href={link.href} 
            class={`hover:text-brand-teal underline underline-offset-4 decoration-white/10 ${link.class || ''}`}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

{ variant === 'centered' && (
  <nav aria-label="Related CAT guides" class="mt-16 flex flex-wrap justify-center gap-x-6 gap-y-3 text-sm text-zinc-400">
    {links.map(link => (
      <a 
        href={link.href} 
        class={`hover:text-brand-teal underline underline-offset-4 decoration-white/10 ${link.class || ''}`}
      >
        {link.label}
      </a>
    ))}
  </nav>
)}

{ variant === 'simple' && (
  <nav aria-label="Related guides" class="mt-16 flex flex-wrap gap-x-6 gap-y-3 text-sm text-zinc-400">
    {links.map(link => (
      <a 
        href={link.href} 
        class={`hover:text-brand-teal underline underline-offset-4 ${link.class || ''}`}
      >
        {link.label}
      </a>
    ))}
  </nav>
)}