---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import AnnouncementBar from "../components/AnnouncementBar";
import Footer from "../components/Footer.astro";
import { buildPublisher } from "../utils/schema";

interface Props {
  title: string;
  description?: string;
  keywords?: string[];
  noindex?: boolean;
  datePublished?: string;
  dateModified?: string;
  ogType?: "website" | "article";
  ogImage?: string;
  breadcrumb?: { name: string; url: string }[];
  head?: string;
  /** Max-width utility for the content wrapper. Defaults to `max-w-4xl`
   *  (article reading width). Wide/landing pages (e.g. pricing,
   *  cat-syllabus) should pass `max-w-[1800px]`. */
  maxWidth?: string;
}

const {
  title,
  description,
  keywords,
  noindex = false,
  datePublished,
  dateModified,
  ogType = "website",
  ogImage,
  breadcrumb,
  head,
  maxWidth = "max-w-4xl",
} = Astro.props;

// TechArticle (subtype of Article) auto-emitted when ogType="article" + datePublished.
// IMPORTANT: pages emitting their own TechArticle/BlogPosting via `head` should
// use Layout directly — CatLayout would produce a duplicate Article schema.
const siteUrl = Astro.site || "https://adapthub.in/";
// String(siteUrl) preserves the trailing slash, matching Layout.astro's @id form.
const siteUrlStr = String(siteUrl);
// Mirror Layout.astro's path normalization (strip .html + trailing slash) so TechArticle @id matches Layout's WebPage @id.
const rawPath = Astro.url.pathname;
const normalizedPath = rawPath === "/index.html" ? "/" : rawPath.replace(/\.html$/, "");
const cleanPath = normalizedPath.replace(/\/$/, "") || "/";
const articleURL = new URL(cleanPath, siteUrl).href;
// Gate on `!head` so pages passing their own Article via `head` don't get a duplicate.
const articleSchema =
  ogType === "article" && datePublished && !head
    ? JSON.stringify({
        "@context": "https://schema.org",
        "@type": "TechArticle",
        "@id": `${articleURL}#techarticle`,
        "headline": title,
        "description": description,
        "datePublished": datePublished,
        "dateModified": dateModified || datePublished,
        "inLanguage": "en-IN",
        "mainEntityOfPage": {
          "@type": "WebPage",
          "@id": articleURL,
        },
        "image": [
          ogImage || new URL("/og-image.png", siteUrl).href,
        ],
        "author": { "@type": "Organization", "name": "AdaptHub" },
        "publisher": buildPublisher(siteUrlStr),
        "isAccessibleForFree": true,
        "url": articleURL,
      })
    : null;

---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  noindex={noindex}
  datePublished={datePublished}
  dateModified={dateModified}
  ogType={ogType}
  ogImage={ogImage}
  breadcrumb={breadcrumb}
>
  <slot name="head" />
  {articleSchema && <script type="application/ld+json" is:inline slot="head" set:html={articleSchema} />}
  {head && <script type="application/ld+json" is:inline slot="head" set:html={head} />}
  <AnnouncementBar client:idle transition:persist />
  <Navbar client:load transition:persist />

  <main id="main-content" class="relative isolate pt-32 md:pt-40 pb-32 overflow-x-clip min-h-[100svh] bg-void selection:bg-brand-teal/30 selection:text-white">
    <div class="background-pulse" aria-hidden="true">
      <slot name="grain" />
    </div>
    <div class={`mx-auto w-full px-4 sm:px-6 md:px-12 lg:px-24 relative z-10 ${maxWidth} mt-8`}>
      <slot />
    </div>
  </main>
  <Footer />
</Layout>

<style>
  @media (prefers-reduced-motion: reduce) {
    .background-pulse { animation: none !important; }
    ::slotted([slot="grain"]) { opacity: 0 !important; }
  }
</style>
