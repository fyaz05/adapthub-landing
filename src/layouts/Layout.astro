---
import "../styles/global.css";
import "@fontsource/geist-sans";
import "@fontsource/geist-mono";
import "@fontsource/lora/400.css";
import "@fontsource/lora/700.css";
import "@fontsource/lora/400-italic.css";
import { ClientRouter } from "astro:transitions";
import { resolvedContent as CONTENT } from "../utils/config";
import { partytownSnippet } from "@qwik.dev/partytown/integration";

import NoiseOverlay from "../components/NoiseOverlay.astro";

interface Props {
  title: string;
  description?: string;
  keywords?: string[];
  noindex?: boolean;
  datePublished?: string;
  dateModified?: string;
  ogType?: "website" | "article";
  /** article:section for ogType=article pages (e.g. blog category). Falls back to "CAT Preparation". */
  articleSection?: string;
  /** article:author for ogType=article pages. Falls back to the brand name. */
  articleAuthor?: string;
  /** Per-page OG image URL (absolute). Defaults to global og-image.png. */
  ogImage?: string;
  /** Optional explicit breadcrumb trail. Each entry is { name, url }.
   *  If omitted, falls back to URL-derived Home + current-page breadcrumb. */
  breadcrumb?: { name: string; url: string }[];
}

const {
  title = CONTENT.metadata.defaultTitle,
  description = CONTENT.metadata.defaultDescription,
  keywords = CONTENT.metadata.defaultKeywords,
  noindex = false,
  datePublished,
  dateModified = datePublished,
  ogType = "website",
  ogImage,
  breadcrumb,
  articleSection,
  articleAuthor,
} = Astro.props;
const siteUrl = Astro.site || "https://adapthub.in";
const rawPath = Astro.url.pathname;
// Strip .html from build paths so URLs resolve cleanly (e.g. /pricing)
const normalizedPath = rawPath === '/index.html' ? '/' : rawPath.replace(/\.html$/, '');
const cleanPath = normalizedPath.replace(/\/$/, '') || '/';
const canonicalURL = new URL(cleanPath, siteUrl);

// Breadcrumb: prefer explicit prop; fall back to URL-derived for backward compat
const pathSegments = normalizedPath.replace(/\/$/, '').split('/').filter(Boolean);
let breadcrumbItems: { "@type": string; position: number; name: string; item: string | { "@type": string; "@id": string } }[];
if (breadcrumb && breadcrumb.length > 0) {
  breadcrumbItems = breadcrumb.map((item, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: item.name,
    item: item.url,
  }));
  } else {
    breadcrumbItems = [
      { "@type": "ListItem", position: 1, name: "Home", item: { "@type": "Thing", "@id": String(siteUrl) } }
    ];
    if (pathSegments.length > 0) {
      const lastSegment = pathSegments[pathSegments.length - 1];
      const pageName = lastSegment.split('-').map((w: string) => w.charAt(0).toUpperCase() + w.slice(1)).join(' ');
      breadcrumbItems.push({
        "@type": "ListItem",
        position: 2,
        name: pageName,
        item: { "@type": "Thing", "@id": canonicalURL.href },
      });
    }
  }

// OG image: prefer per-page override, else fall back to global PNG.
// NOTE: We ship ONLY the PNG og:image. AVIF OG images do not render on
// Twitter, Slack, LinkedIn, WhatsApp, or Discord as of 2025-2026 — the OG
// spec makes the LAST declared og:image win, so AVIF was previously shadowing
// the PNG.
const ogImageURL = ogImage || new URL(CONTENT?.metadata?.ogImageFallback || "/og-image.png", siteUrl).href;
const supportEmail = CONTENT?.links?.support?.replace("mailto:", "") || "support@adapthub.in";

// Partytown config — forward dataLayer.push so GA4 gtag calls reach the worker.
const partytownConfig = {
  forward: ['dataLayer.push'],
  debug: false,
};
---

<!DOCTYPE html>
<html lang="en-IN" class="bg-void relative" style="color-scheme: dark">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin />
    <link rel="preconnect" href="https://www.google-analytics.com" crossorigin />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.google-analytics.com" />

    {/*
      ANALYTICS / SEARCH CONSOLE PLACEHOLDERS
      ───────────────────────────────────────
      GA4 is live via Partytown below (id G-W4K3Z0TPD8).
      To swap IDs or add GTM:
        1. Replace G-W4K3Z0TPD8 with your Measurement ID, or
        2. Uncomment the GTM block and set GTM-XXXXXXX.
      Google Search Console verification:
        Uncomment the meta tag below and paste your token from
        Search Console → Settings → Ownership verification → HTML tag.
    */}
    {/* <meta name="google-site-verification" content="PASTE_GSC_VERIFICATION_TOKEN" /> */}
    {/*
    <!-- Google Tag Manager (optional — prefer GA4-only unless you need GTM) -->
    <script type="text/partytown">
      (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
      new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
      j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
      'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
      })(window,document,'script','dataLayer','GTM-XXXXXXX');
    </script>
    */}

    {/* Partytown — runs third-party scripts (GA4) in a web worker to keep the
        main thread free. This is the single biggest INP win for this site:
        gtag.js otherwise adds 50-150ms to every interaction. */}
    <script is:inline set:html={partytownSnippet(partytownConfig)} />

    {/* GA4 gtag.js — runs through Partytown (type="text/partytown") */}
    <script is:inline type="text/partytown" src="https://www.googletagmanager.com/gtag/js?id=G-W4K3Z0TPD8"></script>
    <script is:inline type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-W4K3Z0TPD8', { anonymize_ip: true });
    </script>

    <link rel="icon" type="image/svg+xml" sizes="any" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#050505" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#050505" />
    <meta name="color-scheme" content="dark" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="geo.region" content="IN" />
    <meta name="geo.placename" content="India" />
    <link rel="author" type="text/plain" href="/humans.txt" />

    {/* Canonical URL — skip on noindex pages (e.g. 404) to avoid confusing crawlers */}
    {!noindex && <link rel="canonical" href={canonicalURL} />}
    <link rel="alternate" hreflang="en-IN" href={canonicalURL} />
    <link rel="alternate" hreflang="x-default" href={canonicalURL} />
    <meta name="robots" content={noindex ? "noindex,nofollow" : "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"} />
    <meta name="googlebot" content={noindex ? "noindex,nofollow" : "index,follow,max-image-preview:large,max-snippet:-1,max-video-preview:-1"} />

    {/* Primary Meta Tags */}
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords.join(", ")} />
    <meta name="author" content={CONTENT.global.brandName} />
    <meta name="application-name" content={CONTENT.global.brandName} />
    <meta name="apple-mobile-web-app-title" content={CONTENT.global.brandName} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="mobile-web-app-capable" content="yes" />

    {/* Open Graph / Facebook — SINGLE PNG og:image for crawler compatibility.
        AVIF OG images do not render on Twitter/Slack/LinkedIn/WhatsApp/Discord. */}
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:locale" content="en_IN" />
    <meta property="og:site_name" content={CONTENT.global.brandName} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:secure_url" content={ogImageURL} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:type" content="image/png" />
    <meta property="og:image:alt" content={`${CONTENT.global.brandName} — ${description}`} />
    {ogType === "article" && datePublished && <meta property="article:published_time" content={datePublished} />}
    {ogType === "article" && dateModified && <meta property="article:modified_time" content={dateModified} />}
    {ogType === "article" && <meta property="article:author" content={articleAuthor ?? CONTENT.global.brandName} />}
    {ogType === "article" && <meta property="article:section" content={articleSection ?? "CAT Preparation"} />}

    {/* Twitter — PNG for broadest compatibility */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content={`${CONTENT.global.brandName} — ${description}`} />
    {/* <meta name="twitter:site" content="@adapthublabs" /> */}
    {/* <meta name="twitter:creator" content="@adapthublabs" /> */}

    {/* Structured Data — Single @graph for sitewide entities.
        Page-specific schemas (FAQPage, BlogPosting, Product, Course)
        are injected via the head slot on individual pages. */}
    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": `${siteUrl}#organization`,
          "name": CONTENT.global.brandName,
          "url": siteUrl,
          "logo": {
            "@type": "ImageObject",
            "url": new URL(CONTENT.assets.logoLight, siteUrl).href,
            "width": 512,
            "height": 512
          },
          "image": new URL("/og-image.png", siteUrl).href,
          "description": CONTENT.metadata.defaultDescription,
          "email": supportEmail,
          "foundingDate": "2025",
          "founder": {
            "@type": "Person",
            "name": "Fyaz Mohammed",
            "jobTitle": "Founder",
            "sameAs": ["https://www.linkedin.com/in/fyaz05/"]
          },
          "numberOfEmployees": {
            "@type": "QuantitativeValue",
            "minValue": 1,
            "maxValue": 10
          },
          "knowsAbout": [
            "CAT exam preparation",
            "Adaptive learning systems",
            "Educational technology",
            "MBA entrance exams",
            "Zone of Proximal Development"
          ],
          "areaServed": {
            "@type": "Country",
            "name": "India"
          },
          "sameAs": [
            "https://www.instagram.com/adapthublabs/",
            "https://www.linkedin.com/company/adapthub-labs/"
          ],
          "contactPoint": {
            "@type": "ContactPoint",
            "email": supportEmail,
            "contactType": "customer support",
            "areaServed": "IN",
            "availableLanguage": ["English", "Hindi"]
          }
        },
        {
          "@type": "WebSite",
          "@id": `${siteUrl}#website`,
          "name": CONTENT.global.brandName,
          "url": siteUrl,
          "description": CONTENT.metadata.defaultDescription,
          "inLanguage": "en-IN",
          "publisher": {
            "@id": `${siteUrl}#organization`
          }
        },
        {
          "@type": "WebPage",
          "@id": `${canonicalURL.href}#webpage`,
          "name": title,
          "url": canonicalURL.href,
          "description": description,
          "keywords": keywords.join(", "),
          ...(datePublished ? { "datePublished": datePublished } : {}),
          ...(dateModified ? { "dateModified": dateModified } : {}),
          "inLanguage": "en-IN",
          "isPartOf": {
            "@id": `${siteUrl}#website`
          },
          "about": {
            "@id": `${siteUrl}#software`
          },
          "primaryImageOfPage": {
            "@type": "ImageObject",
            "url": ogImageURL
          },
          "speakable": {
            "@type": "SpeakableSpecification",
            "cssSelector": ["h1", "[data-speakable]", "h2"]
          },
          "breadcrumb": {
            "@id": `${canonicalURL.href}#breadcrumb`
          }
        },
        {
          "@type": "BreadcrumbList",
          "@id": `${canonicalURL.href}#breadcrumb`,
          "itemListElement": breadcrumbItems
        },
        {
          "@type": "SoftwareApplication",
          "@id": `${siteUrl}#software`,
          "name": CONTENT.global.brandName,
          "applicationCategory": "EducationalApplication",
          "applicationSubCategory": "CAT Exam Preparation",
          "operatingSystem": "Web",
          "browserRequirements": "Requires JavaScript. Modern browser recommended.",
          "url": siteUrl,
          "description": CONTENT.metadata.defaultDescription,
          "screenshot": new URL("/og-image.png", siteUrl).href,
          "image": new URL("/og-image.png", siteUrl).href,
          "inLanguage": "en-IN",
          "isAccessibleForFree": true,
          "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "INR",
            "availability": "https://schema.org/InStock",
            "category": "Free"
          },
          "featureList": [
            "Adaptive Diagnostic Calibration (ZPD Algorithm)",
            "Socratic AI Coaching with Hint Penalties",
            "Learning Velocity Telemetry (7-day rolling window)",
            "Spaced Repetition Queue (SRS) for memory decay prevention",
            "Mastery-Based Cognitive Locks (5-level progression)",
            "Quality Streaks (>70% accuracy, 15-min minimum sessions)",
            "Distractor Error Tagging (Trap identification & Calculation Errors)",
            "Dynamic Daily Study Plans for CAT 2026",
            "QA, DILR & VARC concept coverage"
          ],
          "publisher": {
            "@id": `${siteUrl}#organization`
          }
        }
      ]
    })} />
    <slot name="head" />

    <ClientRouter />
    <style is:global>
      html,
      body {
        position: relative !important;
        min-height: 100% !important;
      }

      body {
        overflow-x: hidden !important;
      }
    </style>
    
    {/* Low-End Device Detection & Performance Optimization Script */}
    <script is:inline>
      (function() {
        try {
          // 1. Check User Preference
          const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          
          // 2. Check Hardware Concurrency (Logical Cores)
          const logicalProcessors = navigator.hardwareConcurrency || 4;
          
          // 3. Check Device Memory (RAM in GB) - API not available in all browsers
          const deviceMemory = navigator.deviceMemory || 8;
          
          // 4. Heuristic: Flag as "low-end" if cores < 4 or RAM < 4GB
          const isLowEnd = logicalProcessors < 4 || deviceMemory < 4;
          
          // 5. Apply Global Performance Class
          if (prefersReduced || isLowEnd) {
            document.documentElement.classList.add('is-reduced');
            // Optional: Add data attribute for CSS selectors
            document.documentElement.setAttribute('data-performance', 'low');
          } else {
            document.documentElement.setAttribute('data-performance', 'high');
          }

          // 6. Announcement Banner Persistence Check (Anti-Flicker)
          const isDismissed = sessionStorage.getItem("announcement-dismissed") === "true";
          if (isDismissed) {
            document.documentElement.setAttribute('data-announcement', 'dismissed');
          } else {
            document.documentElement.setAttribute('data-announcement', 'visible');
          }

        } catch (e) {
          console.error(e);
        }
      })();
    </script>
  </head>
  <body class="relative min-h-screen">
    {/* Shared SVG filter defs — referenced by NoiseOverlay.astro and per-page
        grain SVGs via `filter: url(#noise-filter)` / `filter="url(#noise-filter)"`.
        Deduplicated from 3 separate feTurbulence declarations. */}
    <svg aria-hidden="true" style="position: absolute; width: 0; height: 0; overflow: hidden; pointer-events: none;">
      <defs>
        <filter id="noise-filter">
          <feTurbulence type="fractalNoise" baseFrequency="0.75" numOctaves="3" stitchTiles="stitch" />
        </filter>
      </defs>
    </svg>
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[10000] focus:px-4 focus:py-2 focus:bg-accent-yellow focus:text-black focus:rounded-full focus:font-bold focus:text-sm focus:shadow-lg"
    >
      Skip to main content
    </a>
    <div class="global-grid"></div>
    <NoiseOverlay />
    <slot />
  </body>
</html>
