---
import CatLayout from "../layouts/CatLayout.astro";
import FaqSection from "../components/FaqSection.astro";
import Callout from "../components/Callout.astro";
import CtaBlock from "../components/CtaBlock.astro";
import RelatedGuides from "../components/RelatedGuides.astro";
import DataTable from "../components/DataTable.astro";

const siteUrl = Astro.site || "https://adapthub.in/";

const faqs = [
  {
    question: "When is the CAT 2026 exam date?",
    answer: "The CAT 2026 exam is expected to be held on Sunday, November 29, 2026. Historically, the exam is conducted on the last Sunday of November. Confirm on iimcat.ac.in when the official notification is out.",
  },
  {
    question: "When will the CAT 2026 notification be released?",
    answer: "The official CAT 2026 notification will likely be released in the last week of July 2026, followed by the start of the registration process in early August.",
  },
  {
    question: "How many months are required to prepare for CAT 2026?",
    answer: "A dedicated preparation window of 3 to 8 months is ideal for CAT 2026. This allows sufficient time for concept building, adaptive practice, and intensive mock test analysis.",
  },
  {
    question: "What is the CAT 2026 eligibility criteria?",
    answer: "Historically, candidates need a bachelor's degree with at least 50% marks (45% for SC/ST/PwD) or equivalent; final-year students can apply. There is typically no age limit and no attempt cap. Always verify the official notification for the year you register.",
  },
  {
    question: "Where do I register for CAT 2026?",
    answer: "Registration is online on the official CAT website (iimcat.ac.in) when the window opens—usually after the July notification. Keep photo, signature, and category certificates ready before applying.",
  },
];
---
<CatLayout
  title="CAT 2026 Exam Date & Notification Timeline | AdaptHub"
  description="Expected CAT 2026 exam date, official notification release, registration timeline, eligibility, and syllabus snapshot. Plan your CAT preparation."
  keywords={["cat 2026 exam date", "cat 2026 notification", "cat 2026 registration", "cat 2026 syllabus", "cat exam date 2026"]}
  ogType="article"
  datePublished="2025-11-01T00:00:00.000Z"
  dateModified="2026-07-01T00:00:00.000Z"
  breadcrumb={[
    { name: "Home", url: String(siteUrl) },
    { name: "CAT 2026 Exam Date", url: new URL("/cat-2026-exam-date", siteUrl).href },
  ]}
>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FAQPage",
        "@id": `${siteUrl}cat-2026-exam-date#faq`,
        "mainEntity": faqs.map((faq) => ({
          "@type": "Question",
          "name": faq.question,
          "acceptedAnswer": { "@type": "Answer", "text": faq.answer },
        })),
      },
    ],
  })} />
  <Callout label="CAT 2026 Snapshot">
    <p><strong>Expected exam:</strong> Sunday, 29 November 2026 (provisional — verify on <a href="https://iimcat.ac.in" target="_blank" rel="noopener noreferrer" class="text-brand-teal hover:underline underline-offset-4">iimcat.ac.in</a>).</p>
    <p><strong>Notification:</strong> Likely last week of July 2026.</p>
    <p><strong>Sections:</strong> VARC (24 Q), DILR (22 Q), QA (22 Q) — 66 total, 120 min, +3/−1 MCQ, 0 penalty TITA.</p><p><strong>Provisional:</strong> Question counts and weightages above reflect recent CAT cycles and may shift slightly year to year.</p></Callout>

  <article>
    <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif tracking-tight mb-8 text-white">CAT 2026 Exam Date, Notification & Syllabus Snapshot</h1>
    <p class="text-zinc-400 text-lg md:text-xl leading-[1.8] mb-12">
      The CAT 2026 exam is <strong>expected on Sunday, 29 November 2026</strong> (provisional — always confirm on <a href="https://iimcat.ac.in" target="_blank" rel="noopener noreferrer" class="text-brand-teal hover:underline underline-offset-4">iimcat.ac.in</a>). This page gives you the expected timeline, eligibility, marking scheme, and a high-level syllabus so you can start planning now.
    </p>

    <h2 class="text-2xl md:text-3xl font-serif text-white tracking-tight mt-16 mb-6">Key dates at a glance (provisional)</h2>
    <DataTable
      headers={[
        { label: "Milestone", scope: "col" },
        { label: "Expected window", scope: "col" },
        { label: "Action", scope: "col", class: "text-brand-teal" },
      ]}
      rows={[
        { cells: [{ content: "Official notification" }, { content: "Last week of July 2026" }, { content: "Bookmark iimcat.ac.in" }] },
        { cells: [{ content: "Registration opens" }, { content: "Early August 2026" }, { content: "Register within 3 days" }] },
        { cells: [{ content: "Admit card release" }, { content: "Late October 2026" }, { content: "Download + verify centre" }] },
        { cells: [{ content: "CAT 2026 exam" }, { content: "<strong>Sunday, 29 Nov 2026</strong>" }, { content: "Exam day protocol ready" }] },
        { cells: [{ content: "Result declaration" }, { content: "Early January 2027" }, { content: "Check percentile + apply" }] },
      ]}
    />

    <h2 class="text-2xl md:text-3xl font-serif text-white tracking-tight mt-16 mb-6">Eligibility (based on recent cycles — verify on notification)</h2>
    <ul class="list-disc pl-6 text-zinc-400 space-y-3 mb-10 leading-[1.75]">
      <li>Bachelor's degree with ≥50% marks (45% for SC/ST/PwD) or equivalent.</li><li>Final-year students eligible (provisional).</li>
      <li>No age limit, no attempt cap.</li>
      <li>Work experience not required.</li>
    </ul>

    <h2 class="text-2xl md:text-3xl font-serif text-white tracking-tight mt-16 mb-6">CAT 2026 exam pattern & marking</h2>
    <ul class="list-disc pl-6 text-zinc-400 space-y-3 mb-10 leading-[1.75]">
      <li><strong>Sections:</strong> VARC (24 Q, 40 min), DILR (22 Q, 40 min), QA (22 Q, 40 min).</li>
      <li><strong>Total:</strong> 66 questions, 198 marks, 120 minutes (40 min/section, no switching).</li>
      <li><strong>Marking:</strong> +3 correct, −1 MCQ wrong, 0 penalty TITA.</li><li><strong>TITA share:</strong> Increasing trend; ~25–30% of questions are non-MCQ.</li>
    </ul>

    <h2 class="text-2xl md:text-3xl font-serif text-white tracking-tight mt-16 mb-6">High-level syllabus map</h2>
    <p class="text-zinc-400 leading-[1.8] mb-6">
      Full breakdown with weightage on the <a href="/cat-syllabus" class="text-brand-teal hover:underline underline-offset-4">CAT syllabus page</a>. Quick reference:
    </p>
    <ul class="list-disc pl-6 text-zinc-400 space-y-3 mb-10 leading-[1.75]">
      <li><strong>VARC (24 Q):</strong> RC (~16 Q), Para Jumbles, Summary, Odd-one-out, Para Completion.</li><li><strong>DILR (22 Q):</strong> Hybrid DI+LR sets, Games & Tournaments, Venn/Set Theory, Seating, Team Selection.</li><li><strong>QA (22 Q):</strong> Arithmetic ~35–50%, Algebra, Geometry/Mensuration, Number System, Modern Math (PnC/Prob).</li>
    </ul>

    <h2 class="text-2xl md:text-3xl font-serif text-white tracking-tight mt-16 mb-6">How to start today</h2>
    <ol class="list-decimal pl-6 text-zinc-400 space-y-3 mb-10 leading-[1.75]">
      <li>Bookmark <a href="https://iimcat.ac.in" target="_blank" rel="noopener noreferrer" class="text-brand-teal hover:underline underline-offset-4">iimcat.ac.in</a> for the official notification.</li>
      <li>Take a diagnostic mock to set your baseline (free on AdaptHub).</li><li>Pick a study plan: <a href="/cat-study-plan-2026" class="text-brand-teal hover:underline underline-offset-4">6-month standard</a> or <a href="/cat-preparation-without-coaching" class="text-brand-teal hover:underline underline-offset-4">compressed self-study</a>.</li><li>Start free adaptive calibration on <a href="/pricing" class="text-brand-teal hover:underline underline-offset-4">AdaptHub</a> — it builds your daily focus from day 1.</li></ol>

    <CtaBlock text="Start Free Adaptive Prep" />

    <FaqSection faqs={faqs} title="Frequently Asked Questions" />

    <RelatedGuides
      links={[
        { label: "CAT syllabus 2026", href: "/cat-syllabus" },
        { label: "CAT 2026 study plan", href: "/cat-study-plan-2026" },
        { label: "How to analyse mocks", href: "/cat-mock-analysis" },
        { label: "Self-study without coaching", href: "/cat-preparation-without-coaching" },
      ]}
    />
  </article>
</CatLayout>