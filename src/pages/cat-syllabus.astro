---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar";
import AnnouncementBar from "../components/AnnouncementBar";
import Footer from "../components/Footer.astro";
import FaqSection from "../components/FaqSection.astro";
import Callout from "../components/Callout.astro";
import CtaBlock from "../components/CtaBlock.astro";
import RelatedGuides from "../components/RelatedGuides.astro";
import { resolvedContent as CONTENT } from "../utils/config";
import { buildOffer } from "../utils/schema";

// Rank model (70/20/10 study-priority heuristic, not official IIM weightage):
// 1 = Core (the "70% block"), 2 = Secondary (the "20% block"), 3 = Niche (the "10% block").
const RANK_LABEL = { 1: "Core", 2: "Secondary", 3: "Niche" };
const RANK_CLASS = {
  1: "bg-rose-500/10 border-rose-500/30 text-rose-300",
  2: "bg-amber-500/10 border-amber-500/30 text-amber-300",
  3: "bg-sky-500/10 border-sky-500/30 text-sky-300",
};

const syllabusData = [
  {
    id: "VARC",
    title: "Verbal Ability & Reading Comprehension",
    questions: "24 Qs",
    time: "40 Mins",
    note: "Grammar is not tested in CAT. Focus entirely on comprehension, logical flow, and paragraph structure.",
    topics: [
      { name: "Reading Comprehension", weight: "16 Qs (4 Passages)", rank: 1, details: "Dense passages from Philosophy, Sociology, History, Science, Economics, and Modern Technology. Question types: Central Idea, Inference, Tone, Author's Purpose, Fact vs Judgment.", strategy: "Around 70% of VARC. Build a daily reading habit (Aeon, Guardian, philosophy, sociology) and analyse author intent, not just content." },
      { name: "Para Jumbles", weight: "2-3 Qs", rank: 1, details: "Rearranging 4-5 sentences into a logically coherent paragraph. Primarily TITA format. Requires identification of transitional words, connectors, and logical flow.", strategy: "Usually TITA (no negative marking). Lock mandatory pairs (pronouns, full-name→acronym) before scanning options." },
      { name: "Para Summary", weight: "2-3 Qs", rank: 1, details: "Selecting the most accurate summary of a given paragraph from closely worded, deceptive distractor options. Tests comprehension and precision.", strategy: "Pick the core argument; reject options fixated on examples or using extreme language." },
      { name: "Odd Sentence Out", weight: "1-2 Qs", rank: 1, details: "Identifying the contextually irrelevant sentence from a cluster of 5 sentences. Tests structural coherence and theme identification.", strategy: "Usually TITA. Find the unifying theme; the outlier breaks the logical flow." },
      { name: "Para Completion", weight: "0-1 Qs", rank: 2, details: "Selecting the sentence that logically completes a given paragraph. Tests inference, logical closure, and contextual continuity.", strategy: "Often TITA. The missing line must conclude the argument without introducing new, unlinked ideas." }
    ]
  },
  {
    id: "DILR",
    title: "Data Interpretation & Logical Reasoning",
    questions: "22 Qs",
    time: "40 Mins",
    note: "Pure chart DI is rare. Modern CAT tests Hybrid Sets that mix logic with arithmetic and data.",
    topics: [
      { name: "Data Interpretation", weight: "10-12 Qs", rank: 2, details: "Bar Graphs, Line Charts, Pie Charts, Tables, Caselets, Combination Graphs, Scatter Plots, Tables with Missing Values. Data-driven decision-making under time pressure.", strategy: "Never standalone now — learn calculation shortcuts (growth rates, pie-degree→%) to deploy inside Hybrid sets." },
      { name: "Logical Reasoning", weight: "10-12 Qs", rank: 2, details: "Linear & Circular Seating Arrangements, Constraint-based Puzzles, Binary Logic, Scheduling, Matrix Arrangements, Blood Relations, Truth & Lie, Selection with Conditions, Quant-based LR.", strategy: "Practise full constraint parsing; hybrid sets dominate the modern paper." },
      { name: "Games & Tournaments", weight: "0-1 Set", rank: 1, details: "Knockout Tournaments, Round Robin formats, Seeding logic, League-based scoring, and Logic-driven games.", strategy: "High ROI. Master win/loss/draw point logic and bracket structures." },
      { name: "Venn Diagrams & Sets", weight: "0-1 Set", rank: 1, details: "2-Set, 3-Set, 4-Set Venn diagrams, Maxima-Minima intersecting logic in sets.", strategy: "Master the algebraic equations for 3-4 variable intersections and at-least/at-most constraints." }
    ]
  },
  {
    id: "QA",
    title: "Quantitative Aptitude",
    questions: "22 Qs",
    time: "40 Mins",
    note: "Sorted by the 70/20/10 rule. Arithmetic and core Algebra dominate the exam.",
    topics: [
      { name: "Arithmetic", weight: "8-10 Qs (~40%)", rank: 1, details: "Percentages, Successive Changes, Profit & Loss, Discounts, Simple & Compound Interest, Installments, Ratio & Proportion, Time Speed & Distance, Time & Work, Averages, Weighted Average, Mixtures & Alligations.", strategy: "Foundation first: Percentages, Ratio, TSD, Time & Work, P&L under adaptive difficulty before anything else." },
      { name: "Algebra", weight: "5-6 Qs", rank: 1, details: "Linear & Quadratic Equations, Polynomials, Inequalities, Logarithms, Functions, Sequences & Series, Maxima & Minima.", strategy: "Treat Equations, Inequalities, Functions and Logs as one continuum; focus on integer/root behaviour." },
      { name: "Geometry & Mensuration", weight: "4-5 Qs", rank: 2, details: "Lines & Angles, Triangles, Quadrilaterals, Circles, Polygons, Coordinate Geometry, 2D/3D Mensuration.", strategy: "Formula fluency plus visualization — triangles and circles carry the most tested sub-topics." },
      { name: "Number System", weight: "1-2 Qs", rank: 2, details: "LCM/HCF, Divisibility Rules, Remainders, Factorials, Base Systems, Last Digits, Units Digit.", strategy: "Properties, divisibility, cyclicity — quick wins once the concepts click." },
      { name: "Modern Math", weight: "1-2 Qs", rank: 1, details: "Progressions, Permutations & Combinations, Probability, Set Theory.", strategy: "PnC and Probability are Rank 1 priorities; link the Venn work heavily to DILR." }
    ]
  }
];

const faqs = [
  {
    question: "Is the CAT syllabus officially released by IIMs?",
    answer: "No. IIMs do not release an official syllabus for CAT. The exam pattern and topics are inferred from previous years' papers. The core sections (VARC, DILR, QA) and their fundamental topic areas have remained consistent for over a decade."
  },
  {
    question: "How many questions and what is the marking scheme?",
    answer: "CAT has 66 questions across 3 sections, totaling 198 marks. Each correct answer awards +3 marks. For MCQs, there is a penalty of -1 mark for incorrect answers. TITA (Type In The Answer) questions carry no negative marking."
  },
  {
    question: "Which section has the highest weightage?",
    answer: "VARC carries 24 questions (72 marks), while both DILR and QA carry 22 questions (66 marks each). However, all three sections are equally important since IIMs require a minimum sectional percentile alongside the overall percentile for shortlisting."
  },
  {
    question: "What are the highest weightage topics in QA?",
    answer: "Arithmetic dominates the QA section, consistently accounting for approximately 40% of the questions (8-10 out of 22). Within Arithmetic, Time Speed & Distance, Percentages, and Ratio & Proportion are the most frequently tested sub-topics."
  },
  {
    question: "Has the CAT exam pattern changed recently?",
    answer: "The current format of 66 questions in 120 minutes (40 minutes per section) with a mix of MCQs and TITA has been stable since CAT 2021. The trend shows an increase in TITA questions, which carry no negative marking and require stronger conceptual clarity."
  }
];

// Safe fallback for Astro.site
const siteUrl = Astro.site || "https://adapthub.in/";
const pricingURL = new URL("pricing", siteUrl).href;
---

<Layout 
  title={CONTENT.metadata?.catSyllabus?.title || "CAT Syllabus 2026 | Structural Breakdown"}
  description={CONTENT.metadata?.catSyllabus?.description || "Comprehensive, data-driven mapping of the Common Admission Test. Exact topic divisions and historical weightage logic."}
  keywords={Array.isArray(CONTENT.metadata.catSyllabus?.keywords) ? CONTENT.metadata.catSyllabus.keywords : []}
>
  <script slot="head" type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@graph": [
      {
        "@type": "FAQPage",
        "@id": `${siteUrl}cat-syllabus#faq`,
        "mainEntity": faqs.map(faq => ({
          "@type": "Question",
          "name": faq.question,
          "acceptedAnswer": { "@type": "Answer", "text": faq.answer }
        }))
      },
      {
        "@type": "Course",
        "@id": `${siteUrl}cat-syllabus#course`,
        "name": "CAT 2026 Exam Preparation — Full Syllabus",
        "description": "A comprehensive breakdown of the CAT 2026 syllabus covering all three sections: Verbal Ability & Reading Comprehension (VARC), Data Interpretation & Logical Reasoning (DILR), and Quantitative Aptitude (QA), with historical topic weightage and question distribution.",
        "provider": {
          "@type": "Organization",
          "@id": `${siteUrl}#organization`,
          "name": "AdaptHub"
        },
        "url": new URL("cat-syllabus", siteUrl).href,
        "inLanguage": "en-IN",
        "isAccessibleForFree": true,
        "educationalLevel": "PostSecondary",
        "teaches": [
          "Verbal Ability & Reading Comprehension",
          "Data Interpretation & Logical Reasoning",
          "Quantitative Aptitude"
        ],
        "hasCourseInstance": {
          "@type": "CourseInstance",
          "courseMode": "online",
          "courseWorkload": "PT14H",
          "startDate": "2026-06-01",
          "endDate": "2026-11-29",
          "inLanguage": "en-IN",
          "location": {
            "@type": "VirtualLocation",
            "url": new URL("cat-syllabus", siteUrl).href
          },
          "offers": buildOffer({
            url: pricingURL,
            siteUrl: String(siteUrl),
          })
        }
      }
    ]
  })}></script>

  <AnnouncementBar client:idle transition:persist />
  <Navbar client:load transition:persist />

  <main id="main-content" class="relative isolate pt-32 md:pt-40 pb-32 overflow-x-clip min-h-[100svh] bg-void selection:bg-brand-teal/30 selection:text-white">
    
    {/* ── Environment & Atmosphere ── */}
    <div class="background-pulse" aria-hidden="true"></div>

    {/* Cinematic Film Grain */}
    <svg class="absolute inset-0 w-full h-full pointer-events-none z-[1] opacity-[0.035]" aria-hidden="true">
      <filter id="syllabus-grain">
        <feTurbulence type="fractalNoise" baseFrequency="0.75" numOctaves="4" stitchTiles="stitch" />
        <feColorMatrix type="saturate" values="0" />
      </filter>
      <rect width="100%" height="100%" filter="url(#syllabus-grain)" />
    </svg>

    {/* Ambient Architectural Grid Lines */}
    <div class="absolute inset-0 pointer-events-none flex justify-center z-[1] opacity-30 overflow-hidden" aria-hidden="true">
      <div class="w-full max-w-[1800px] h-full flex justify-between px-4 sm:px-6 md:px-12 lg:px-24">
        <div class="w-px h-full bg-gradient-to-b from-transparent via-white/[0.05] to-transparent"></div>
        <div class="w-px h-full bg-gradient-to-b from-transparent via-white/[0.05] to-transparent hidden md:block"></div>
        <div class="w-px h-full bg-gradient-to-b from-transparent via-white/[0.05] to-transparent"></div>
      </div>
    </div>

    <div class="container mx-auto px-4 sm:px-6 md:px-12 lg:px-24 relative z-10 max-w-[1800px] mt-8 md:mt-16">
      
      {/* ── Editorial Hero Header ── */}
      <header class="mb-20 md:mb-32 page-stagger" style="--i:0">
        


        <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 items-end">
          
          {/* Narrative Anchor */}
          <div class="lg:col-span-5 xl:col-span-6">
            <h1 class="text-[3.5rem] sm:text-5xl md:text-6xl lg:text-7xl font-serif text-white tracking-tighter leading-none mb-8">
              CAT Syllabus 2026 <br />
              <span class="italic text-brand-teal block pb-2 sm:ml-8 mt-2 md:mt-4">Full Breakdown.</span>
            </h1>
            
            <p class="speakable-content text-zinc-400 font-sans text-lg md:text-xl leading-[1.7] tracking-wide border-l-2 border-brand-teal/30 pl-6">
              The complete, data-driven CAT syllabus breakdown. Exact topic divisions, historical weightage, and structural analysis for VARC, DILR, and QA.
            </p>
          </div>

          {/* Monumental Telemetry HUD */}
          <div class="lg:col-span-7 xl:col-span-6 border border-white/10 bg-white/[0.01] backdrop-blur-sm p-8 md:p-12 relative overflow-hidden group">
            {/* Ambient Sweep */}
            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-brand-teal/[0.03] to-transparent -translate-x-full group-hover:animate-[sweep_2s_ease-in-out]" aria-hidden="true"></div>
            
            <div class="flex items-center gap-2 mb-8 border-b border-white/[0.06] pb-4">
              <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse shadow-[0_0_8px_rgba(16,185,129,0.8)]" aria-hidden="true"></span>
              <span class="font-mono text-[9px] text-zinc-400 uppercase tracking-[0.2em]">Global Parameters (CAT 2026)</span>
            </div>

            <div class="grid grid-cols-3 gap-4 md:gap-8 divide-x divide-white/10">
              
              <div class="flex flex-col items-center sm:items-start text-center sm:text-left">
                <span class="font-serif text-4xl sm:text-5xl md:text-6xl text-white tracking-tighter leading-none mb-3 drop-shadow-[0_0_20px_rgba(255,255,255,0.1)]">66</span>
                <span class="font-mono text-[9px] sm:text-[10px] text-zinc-400 uppercase tracking-[0.2em]">Total Qs</span>
              </div>
              
              <div class="flex flex-col items-center sm:items-start text-center sm:text-left pl-4 md:pl-8">
                <span class="font-serif text-4xl sm:text-5xl md:text-6xl text-white tracking-tighter leading-none mb-3 drop-shadow-[0_0_20px_rgba(255,255,255,0.1)]">120</span>
                <span class="font-mono text-[9px] sm:text-[10px] text-zinc-400 uppercase tracking-[0.2em]">Minutes</span>
              </div>

              <div class="flex flex-col items-center sm:items-start text-center sm:text-left pl-4 md:pl-8">
                <span class="font-serif text-4xl sm:text-5xl md:text-6xl text-white tracking-tighter leading-none mb-3 drop-shadow-[0_0_20px_rgba(255,255,255,0.1)]">198</span>
                <span class="font-mono text-[9px] sm:text-[10px] text-zinc-400 uppercase tracking-[0.2em]">Total Marks</span>
              </div>

            </div>
          </div>

        </div>
      </header>

      {/* ── Priority Rank Legend (70/20/10 study-priority model) ── */}
      <section class="mb-16 md:mb-24 page-stagger" style="--i:1">
        <div class="border border-white/10 bg-white/[0.01] p-6 sm:p-8">
          <p class="font-mono text-[10px] md:text-xs text-brand-teal uppercase tracking-[0.2em] mb-4">[ How to use this tracker ]</p>
          <p class="text-zinc-300 font-sans text-sm md:text-base leading-relaxed mb-5">
            Topics are grouped by a <strong>70/20/10 study-priority model</strong> — a planning heuristic, not official IIM weightage.
            Master the <strong>Core</strong> block first, then <strong>Secondary</strong>, then <strong>Niche</strong>.
          </p>
          <div class="flex flex-wrap gap-3">
            <span class="inline-flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.15em] bg-rose-500/10 border border-rose-500/30 text-rose-300 px-3 py-1.5 rounded">Rank 1 · Core · 70% block</span>
            <span class="inline-flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.15em] bg-amber-500/10 border border-amber-500/30 text-amber-300 px-3 py-1.5 rounded">Rank 2 · Secondary · 20% block</span>
            <span class="inline-flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.15em] bg-sky-500/10 border border-sky-500/30 text-sky-300 px-3 py-1.5 rounded">Rank 3 · Niche · 10% block</span>
          </div>
        </div>
      </section>

      {/* ── GEO: TL;DR / Key Takeaways Box for AI Overviews ── */}
      <div class="mb-16 md:mb-24 page-stagger" style="--i:2">
        <Callout label="Key Takeaways" cornerTabs>
          <ul class="space-y-3 speakable-content text-zinc-300 font-sans text-base md:text-lg leading-relaxed">
            <li class="flex items-start gap-3">
              <span class="text-brand-teal mt-1 select-none">›</span>
              <span><strong>Structure:</strong> 66 questions across 3 sections in 120 minutes (40 mins per section).</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brand-teal mt-1 select-none">›</span>
              <span><strong>Sections:</strong> VARC (24 Qs), DILR (22 Qs), QA (22 Qs).</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="text-brand-teal mt-1 select-none">›</span>
              <span><strong>Marking:</strong> +3 for correct answers, −1 for wrong MCQs, 0 penalty for TITA questions.</span>
            </li>
               <li class="flex items-start gap-3">
               <span class="text-brand-teal mt-1 select-none">›</span>
               <span><strong>Syllabus Source:</strong> No official IIM syllabus exists; topics are rigorously inferred from past year papers. Verify the official notification and exact pattern at <a href="https://iimcat.ac.in" target="_blank" rel="noopener noreferrer" class="text-brand-teal hover:underline underline-offset-4">iimcat.ac.in</a> when released.</span>
             </li>
             <li class="flex items-start gap-3">
               <span class="text-brand-teal mt-1 select-none">›</span>
               <span><strong>Provisional:</strong> Question counts and weightages above reflect recent CAT cycles and may shift slightly year to year.</span>
             </li>
          </ul>
        </Callout>
      </div>

      {/* ── Syllabus Matrices (The Interactive Ledger) ── */}
      <div class="space-y-16 md:space-y-24">
        {syllabusData.map((section, index) => (
           <section class="page-stagger relative border border-white/10 bg-white/[0.01]" style={`--i:${3 + index}`}>
            
            {/* Sticky Section Control Bar */}
            <div class="sticky top-[72px] sm:top-20 z-30 bg-zinc-950/80 backdrop-blur-xl border-b border-white/10 py-5 px-6 md:px-10 flex flex-col sm:flex-row sm:items-center justify-between gap-4">
              
              <div class="flex items-center gap-4 md:gap-6">
                <span class="font-mono text-[10px] sm:text-xs text-brand-teal uppercase tracking-[0.2em] bg-brand-teal/5 border border-brand-teal/20 px-2 py-1 shrink-0">
                  SEC.0{index + 1}
                </span>
                <h2 class="text-xl md:text-2xl font-serif text-white tracking-tight truncate">
                  <span class="hidden sm:inline-block font-bold mr-2">{section.id} —</span>
                  {section.title}
                </h2>
              </div>

              <div class="flex items-center gap-6 font-mono text-[10px] text-zinc-400 uppercase tracking-[0.1em] shrink-0">
                <div class="flex items-center gap-2">
                  <span class="w-1 h-1 bg-zinc-600 rounded-full"></span>
                  {section.questions}
                </div>
                <div class="w-px h-4 bg-white/10"></div>
                <div class="flex items-center gap-2">
                  <span class="w-1 h-1 bg-zinc-600 rounded-full"></span>
                  {section.time}
                </div>
              </div>
            </div>

            {section.note && (
              <p class="px-6 md:px-10 py-4 text-zinc-400 text-sm border-b border-white/[0.06]">{section.note}</p>
            )}

            {/* The Tabular Topic Ledger */}
            <div class="flex flex-col">
              {section.topics.map((topic) => (
                <div class="topic-row group relative flex flex-col md:flex-row border-b border-white/[0.06] last:border-b-0 transition-colors duration-500 hover:bg-white/[0.02]">
                  
                  {/* Left Active Hardware Line */}
                  <div class="absolute left-0 top-0 bottom-0 w-[2px] bg-brand-teal scale-y-0 group-hover:scale-y-100 transition-transform duration-500 origin-top ease-out pointer-events-none hidden md:block" aria-hidden="true"></div>
                  
                  {/* Left Column: Topic Identity & Weightage */}
                  <div class="md:w-[35%] lg:w-[30%] shrink-0 py-6 md:py-10 px-6 md:pl-10 md:pr-8 border-b md:border-b-0 md:border-r border-white/[0.04] relative z-10 flex flex-col justify-start">
                    <h3 class="font-serif text-xl sm:text-2xl text-zinc-100 group-hover:text-white leading-snug tracking-tight mb-4 transition-colors duration-300">
                      {topic.name}
                    </h3>
                    
                    <div class="mt-auto">
                      <span class="font-mono text-[9px] text-zinc-400 uppercase tracking-[0.2em] block mb-2">Historical Weightage</span>
                      <div class="inline-flex items-center gap-2 font-mono text-[10px] md:text-xs text-brand-teal uppercase tracking-[0.1em] bg-brand-teal/5 border border-brand-teal/20 px-3 py-1.5">
                        <span class="w-1.5 h-1.5 bg-brand-teal/80 rounded-full" aria-hidden="true"></span>
                        {topic.weight}
                      </div>
                      <div class="mt-3">
                        <span class={`font-mono text-[9px] uppercase tracking-[0.15em] px-2 py-1 rounded border ${RANK_CLASS[topic.rank as 1 | 2 | 3]}`}>{RANK_LABEL[topic.rank as 1 | 2 | 3]} · Rank {topic.rank}</span>
                      </div>
                    </div>
                  </div>

                  {/* Right Column: Explanatory Prose + Strategy */}
                  <div class="md:w-[65%] lg:w-[70%] py-6 md:py-10 px-6 md:px-10 relative z-10 flex items-center">
                    <div class="max-w-3xl">
                      <p class="text-zinc-400 group-hover:text-zinc-300 font-sans text-base md:text-[1.0625rem] leading-[1.75] tracking-wide transition-colors duration-300">
                        {topic.details}
                      </p>
                      <p class="mt-3 text-sm text-zinc-300/90 leading-relaxed border-l-2 border-brand-teal/30 pl-4">
                        <span class="font-mono text-[9px] uppercase tracking-[0.2em] text-brand-teal mr-2">Strategy</span>{topic.strategy}
                      </p>
                    </div>
                  </div>

                </div>
              ))}
            </div>

          </section>
        ))}
      </div>

      <FaqSection faqs={faqs} title="CAT Syllabus FAQs" />

      {/* ── Related guides + CTA ── */}
      <div class="mt-24 md:mt-32 pb-12 page-stagger" style="--i:6">
        <RelatedGuides
          variant="centered"
          links={[
            { label: "CAT 2026 exam date", href: "/cat-2026-exam-date" },
            { label: "CAT 2026 study plan", href: "/cat-study-plan-2026" },
            { label: "How to analyse CAT mocks", href: "/cat-mock-analysis" },
            { label: "VARC strategy", href: "/cat-varc-strategy" },
            { label: "DILR strategy", href: "/cat-dilr-strategy" },
            { label: "Quant strategy", href: "/cat-quant-strategy" },
            { label: "99 percentile plan", href: "/how-to-score-99-percentile-cat" },
            { label: "CAT self-study guide", href: "/cat-preparation-without-coaching" },
            { label: "Adaptive learning for CAT", href: "/adaptive-learning-cat" },
            { label: "CAT strategy blog", href: "/blog" },
          ]}
        />
        <CtaBlock text="Start Free CAT Calibration" />
      </div>

    </div>
  </main>
  
  <Footer />
</Layout>

<style>
  /* ── Sweep Animation for Hero HUD ── */
  @keyframes sweep {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }

  /* ── Native Details/Summary Fixes ── */
  details > summary::-webkit-details-marker {
    display: none;
  }

  /* ── Hardware Guardrails & Performance ── */
  @media (prefers-reduced-motion: reduce) {
    .faq-row *, .topic-row * { transition: none !important; }
    .animate-pulse { animation: none; opacity: 0.8; }
    .group-hover\:animate-\[sweep_2s_ease-in-out\] { animation: none !important; }
  }
</style>
